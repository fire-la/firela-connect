{
  "name": "@firela/billclaw-ui",
  "version": "0.0.1",
  "description": "Unified UI package for BillClaw - React + Vite + Tailwind",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./stores/configStore": {
      "types": "./dist/stores/configStore.d.ts",
      "import": "./dist/stores/configStore.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "wrangler dev",
    "deploy": "wrangler pages deploy dist",
    "lint": "oxlint",
    "format": "oxfmt",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@firela/billclaw-core": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "axios": "^1.12.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.11",
    "hono": "^4.7.0",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^7.2.0",
    "jose": "^6.1.3",
    "lucide-react": "^0.511.0",
    "radix-ui": "^1.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^13.0.0",
    "react-router-dom": "^6.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.25.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "@hono/vite-dev-server": "^0.19.0",
    "@hono/zod-validator": "^0.4.3",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^25.2.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^3.0.0",
    "autoprefixer": "^10.4.16",
    "happy-dom": "^17.0.0",
    "jsdom": "^26.0.0",
    "oxfmt": "^0.1.0",
    "oxlint": "^0.15.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.8.0",
    "vite": "^5.2.0",
    "vitest": "^3.0.0",
    "wrangler": "^3.109.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "billclaw",
    "react",
    "vite",
    "tailwind",
    "ui"
  ],
  "author": "firela",
  "license": "MIT"
}
