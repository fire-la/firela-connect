{
  "name": "@firela/billclaw-connect",
  "version": "0.5.5",
  "description": "OAuth service for BillClaw - provides web interface for financial data provider authentication",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./routes/config": {
      "types": "./dist/routes/config.d.ts",
      "import": "./dist/routes/config.js"
    },
    "./routes/credentials": {
      "types": "./dist/routes/credentials.d.ts",
      "import": "./dist/routes/credentials.js"
    },
    "./routes/plaid": {
      "types": "./dist/routes/plaid.d.ts",
      "import": "./dist/routes/plaid.js"
    },
    "./routes/gmail": {
      "types": "./dist/routes/gmail.d.ts",
      "import": "./dist/routes/gmail.js"
    },
    "./routes/webhooks": {
      "types": "./dist/routes/webhooks.d.ts",
      "import": "./dist/routes/webhooks.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "test": "vitest",
    "lint": "oxlint",
    "format": "oxfmt"
  },
  "dependencies": {
    "@firela/billclaw-core": "workspace:*",
    "@firela/runtime-adapters": "workspace:*",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^25.2.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "oxfmt": "^0.1.0",
    "oxlint": "^0.15.0",
    "supertest": "^7.2.2",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "billclaw",
    "oauth",
    "plaid",
    "gmail",
    "financial",
    "authentication"
  ],
  "author": "firela",
  "license": "MIT"
}
