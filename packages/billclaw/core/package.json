{
  "name": "@firela/billclaw-core",
  "version": "0.5.5",
  "description": "BillClaw Core - Framework-agnostic business logic for financial data import",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    },
    "./storage/file": {
      "types": "./dist/storage/file-adapter.d.ts",
      "import": "./dist/storage/file-adapter.js"
    },
    "./storage/d1": {
      "types": "./dist/storage/d1-adapter.d.ts",
      "import": "./dist/storage/d1-adapter.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    },
    "./webhook": {
      "types": "./dist/webhook/index.d.ts",
      "import": "./dist/webhook/index.js"
    },
    "./connection": {
      "types": "./dist/connection/index.d.ts",
      "import": "./dist/connection/index.js"
    },
    "./oauth": {
      "types": "./dist/oauth/index.d.ts",
      "import": "./dist/oauth/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./relay": {
      "types": "./dist/relay/index.d.ts",
      "import": "./dist/relay/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "lint": "oxlint",
    "format": "oxfmt src/",
    "format:write": "oxfmt -w src/",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "financial-data",
    "plaid",
    "gocardless",
    "banking",
    "transactions",
    "bills",
    "data-sovereignty"
  ],
  "author": "fire-la",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/fire-la/billclaw.git",
    "directory": "packages/core"
  },
  "devDependencies": {
    "@firela/runtime-adapters": "workspace:*",
    "@types/node": "^25.2.0",
    "@types/proper-lockfile": "^4.1.2",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^3.0.0",
    "oxfmt": "^0.1.0",
    "oxlint": "^0.15.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "keytar": "^6.0.1"
  },
  "dependencies": {
    "@firela/parser-cn": "^0.1.2",
    "@firela/parser-core": "^0.1.1",
    "@firela/parser-eu": "^0.1.1",
    "@firela/parser-hk": "^0.1.1",
    "iconv-lite": "0.6.3",
    "jose": "^6.1.3",
    "plaid": "^32.0.0",
    "proper-lockfile": "^4.1.2",
    "ws": "^8.19.0",
    "zod": "^3.25.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
