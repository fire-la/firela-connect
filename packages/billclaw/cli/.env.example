# VLT API Configuration
# Get these values from your Firela VLT backend deployment

# API Base URL (required)
VLT_API_URL=https://ign-dev.firela.io/api/v1

# Authentication token (required for authenticated endpoints)
# Run `billclaw auth login` to obtain this token
VLT_AUTH_TOKEN=your-auth-token-here

# Debug mode (optional)
# Set to 'true' to enable verbose API logging
VLT_DEBUG=false
