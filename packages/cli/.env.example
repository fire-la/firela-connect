# IGN API Configuration
# Get these values from your IGN backend deployment

# API Base URL (required)
IGN_API_URL=http://localhost:3333/api/v1

# Authentication token (required for authenticated endpoints)
# Run `billclaw auth login` to obtain this token
IGN_AUTH_TOKEN=your-auth-token-here

# Debug mode (optional)
# Set to 'true' to enable verbose API logging
IGN_DEBUG=false
